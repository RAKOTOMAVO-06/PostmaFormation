									"pm.test(\"Status code is 200\", function () {pm.response.to.have.status(200);});\r",
									"//Extraire le token d'accès de la réponse\r",
									"const responsJson=pm.response.json();\r",
									"\r",
									"// Sauvegarder dans lavariable d'environnement\r",
									"pm.environment.set(\"Access_Token\", responsJson.accessToken);\r",
									"console.log(\"Token d'accès enregistré : \\n\" + responsJson.accessToken);\r",
									"console.log(\"voici ma variable\\n\"+pm.environment.get(\"base-url\")\r",
